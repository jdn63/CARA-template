  "climate_impact": {
    "tick_range_expansion": {
      "description": "Warming temperatures expanding blacklegged tick habitat northward and to higher elevations",
      "multiplier": 1.15,
      "notes": "Wisconsin tick populations have expanded significantly since 2000. Climate models project continued northward expansion."
    },
    "extended_season": {
      "description": "Earlier spring and later fall extending tick and mosquito active seasons",
      "multiplier": 1.10,
      "notes": "Active season has extended by approximately 2-3 weeks since 1990s"
    },
    "mosquito_habitat": {
      "description": "Increased precipitation and warmer temperatures creating more mosquito breeding habitat",
