  "metadata": {
    "description": "County-level baseline data for vector-borne disease risk assessment in Wisconsin",
    "version": "1.0.0",
    "last_updated": "2025-01-15",
    "sources": [
      "Wisconsin DHS Lyme Disease Surveillance Reports (2018-2023)",
      "CDC ArboNET West Nile Virus Surveillance (2018-2023)",
      "Wisconsin DHS Tick-Borne Disease Summary Reports",
      "USDA Forest Service National Land Cover Database (NLCD 2021)",
      "Wisconsin DNR Deer Population Estimates (2023)",
      "U.S. Census Bureau ACS 5-Year Estimates - Rural/Urban Classification"
    ],
    "diseases_covered": [
      "Lyme disease (Borrelia burgdorferi)",
      "Anaplasmosis (Anaplasma phagocytophilum)",
      "Ehrlichiosis (Ehrlichia species)",
      "West Nile Virus (WNV)"
    ],
    "case_rate_tiers": {
      "very_high": "Annual incidence >100 per 100,000 population",
      "high": "Annual incidence 50-100 per 100,000 population",
      "moderate": "Annual incidence 20-50 per 100,000 population",
      "low": "Annual incidence 5-20 per 100,000 population",
      "minimal": "Annual incidence <5 per 100,000 population"
    },
    "notes": "Wisconsin consistently ranks in the top 5 nationally for Lyme disease incidence. The northwestern and north-central counties have the highest tick-borne disease rates. Climate warming is expanding tick and mosquito habitat northward and extending active seasons."
  },
