  "seasonal_risk_factors": {
    "tick_season": {
      "peak_months": [5, 6, 7],
      "active_months": [4, 5, 6, 7, 8, 9, 10],
      "notes": "Primary tick season April-October, peak May-July. Blacklegged tick (Ixodes scapularis) is primary Lyme vector."
    },
    "mosquito_season": {
      "peak_months": [7, 8],
      "active_months": [6, 7, 8, 9],
      "notes": "Mosquito season June-September, peak July-August. Culex species are primary WNV vectors."
    }
