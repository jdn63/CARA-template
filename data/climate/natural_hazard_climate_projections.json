{
  "metadata": {
    "description": "Climate change projections for Wisconsin natural hazards",
    "version": "1.0.0",
    "last_updated": "2026-02-06",
    "sources": [
      "NOAA State Climate Summaries - Wisconsin (2022)",
      "IPCC AR6 Working Group I Chapter 11 (2021)",
      "Wisconsin Initiative on Climate Change Impacts (WICCI) 2021 Assessment",
      "EPA Climate Change Indicators (2024)",
      "Great Lakes Integrated Sciences and Assessments (GLISA)"
    ],
    "projection_period": "2030-2050 (mid-century, RCP4.5/SSP2-4.5)",
    "baseline_period": "1986-2005"
  },
  "flood": {
    "exposure_multiplier": 1.20,
    "notes": "NOAA/WICCI: 10-20% increase in heavy precipitation events (>2 inches/day) in Great Lakes region by 2050. Wisconsin has seen 37% increase in extreme precipitation since 1950s.",
    "sub_factors": {
      "precipitation_intensity": 1.25,
      "flash_flood_frequency": 1.30,
      "spring_snowmelt_flooding": 1.10,
      "urban_runoff": 1.15
    },
    "confidence": "high",
    "regional_variation": {
      "southern_wisconsin": 1.25,
      "central_wisconsin": 1.20,
      "northern_wisconsin": 1.15
    }
  },
  "tornado": {
    "exposure_multiplier": 1.12,
    "notes": "IPCC AR6: Increasing atmospheric instability may increase severe convective storm environments by 10-15%. Research suggests tornado alley shifting eastward toward Great Lakes. Uncertainty remains high.",
    "sub_factors": {
      "convective_available_potential_energy": 1.15,
      "severe_weather_environments": 1.12,
      "season_length_extension": 1.10
    },
    "confidence": "medium",
    "regional_variation": {
      "southern_wisconsin": 1.15,
      "central_wisconsin": 1.12,
      "northern_wisconsin": 1.08
    }
  },
  "winter_storm": {
    "exposure_multiplier": 1.08,
    "notes": "NOAA/WICCI: Mixed effects - fewer but more intense winter storms projected. Lake-effect snow may increase 10-20% with warmer Great Lakes water. More ice storms as temperatures oscillate around freezing. Shorter snow season overall.",
    "sub_factors": {
      "storm_intensity": 1.15,
      "ice_storm_frequency": 1.25,
      "lake_effect_snow": 1.18,
      "blizzard_frequency": 0.92,
      "freeze_thaw_cycles": 1.20
    },
    "confidence": "medium",
    "regional_variation": {
      "southern_wisconsin": 1.05,
      "central_wisconsin": 1.08,
      "northern_wisconsin": 1.12
    }
  },
  "thunderstorm": {
    "exposure_multiplier": 1.18,
    "notes": "EPA/NOAA: 15-30% increase in severe thunderstorm environments projected by 2050. Warmer atmosphere holds more moisture, increasing severe weather energy. Derecho and straight-line wind events may increase significantly.",
    "sub_factors": {
      "severe_thunderstorm_frequency": 1.20,
      "hail_events": 1.15,
      "straight_line_wind": 1.25,
      "lightning_density": 1.12
    },
    "confidence": "medium-high",
    "regional_variation": {
      "southern_wisconsin": 1.22,
      "central_wisconsin": 1.18,
      "northern_wisconsin": 1.12
    }
  },
