# CARA Template — Environment Variables
# Copy this to .env and fill in values for local development.
# For production, set these in your deployment platform's secret manager.
# NEVER commit .env files with real values to version control.

# Required
SESSION_SECRET=your-secure-random-secret-here
DATABASE_URL=postgresql://cara:password@localhost:5432/cara

# Profile selection: 'international' or 'us_state'
CARA_PROFILE=international

# CARA version identifier
CARA_VERSION=1.0.0

# Set to 0 to disable background data refresh scheduler
ENABLE_SCRAPERS=1

# Flask settings
FLASK_ENV=production

# Optional: Sentry error monitoring
SENTRY_DSN=

# Global connectors (international profile)
# ACLED — free registration required at acleddata.com
ACLED_API_KEY=
ACLED_EMAIL=

# EM-DAT — free registration required at emdat.be
EMDAT_API_KEY=

# OpenAQ — optional, improves rate limits (register at openaq.org)
OPENAQ_API_KEY=

# NOAA Climate Data Online — optional, improves rate limits
NOAA_CDO_TOKEN=

# US state connectors (us_state profile only)
# AirNow — free key at docs.airnowapi.org
AIRNOW_API_KEY=

# US Census Bureau — free key at api.census.gov
CENSUS_API_KEY=

# OpenWeatherMap — optional, free key at openweathermap.org
OPENWEATHERMAP_API_KEY=
