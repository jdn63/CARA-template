databases:
  - name: cara-db
    databaseName: cara
    user: cara
    region: oregon
    postgresMajorVersion: "16"
    ipAllowList: []

services:
  - type: web
    name: cara
    runtime: python
    region: oregon
    buildCommand: pip install -r requirements.txt
    startCommand: gunicorn --bind 0.0.0.0:$PORT -c gunicorn.conf.py main:app
    envVars:
      - key: SESSION_SECRET
        generateValue: true
      - key: DATABASE_URL
        fromDatabase:
          name: cara-db
          property: connectionString
      - key: PYTHON_VERSION
        value: "3.11.4"
      - key: FLASK_ENV
        value: production
      - key: CARA_PROFILE
        value: international
      - key: ENABLE_SCRAPERS
        value: "1"
      - key: ACLED_API_KEY
        sync: false
      - key: ACLED_EMAIL
        sync: false
      - key: EMDAT_API_KEY
        sync: false
      - key: OPENAQ_API_KEY
        sync: false
      - key: NOAA_CDO_TOKEN
        sync: false
    healthCheckPath: /health
    autoDeploy: true
