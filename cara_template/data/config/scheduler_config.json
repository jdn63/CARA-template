        "openfema_nfip": {
            "description": "NFIP flood insurance claims per county from OpenFEMA (weekly refresh)",
            "refresh_interval_hours": 168,
            "module": "utils.data_source_refresher",
            "function": "refresh_all_openfema_nfip"
        },
        "openfema_hma": {
            "description": "Hazard mitigation projects per county from OpenFEMA (weekly refresh)",
            "refresh_interval_hours": 168,
            "module": "utils.data_source_refresher",
            "function": "refresh_all_openfema_hma"
        },
        "noaa_storm_events": {
            "description": "Historical severe weather events from NOAA NCEI (weekly refresh)",
            "refresh_interval_hours": 168,
            "module": "utils.data_source_refresher",
            "function": "refresh_all_noaa_storm_events"
        },
        "nid_dam_inventory": {
            "description": "USACE National Inventory of Dams - county-level dam counts and hazard classifications (weekly refresh)",
            "refresh_interval_hours": 168,
            "module": "utils.data_source_refresher",
            "function": "refresh_all_nid_dam_inventory"
