# CARA - Comprehensive Automated Risk Assessment
# Environment Variables Configuration
# 
# Copy this file to .env and fill in the values for your deployment.
# NEVER commit .env files with real values to version control.

# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# Flask session secret key (required for secure cookie handling)
# Generate a secure random string: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your-secure-secret-key-here

# PostgreSQL database connection string (required)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://cara:password@localhost:5432/cara

# =============================================================================
# OPTIONAL API KEYS (Some features degrade gracefully without these)
# =============================================================================

# AirNow API key for real-time air quality data
# Get key at: https://docs.airnowapi.org/
AIRNOW_API_KEY=

# OpenWeatherMap API key for weather alerts and forecasts
# Get key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# FEMA Risk Assessment Planning Tool (RAPT) API key
# Get key at: https://www.fema.gov/about/openfema/api
FEMA_RAPT_API_KEY=

# Census Bureau API key for demographic data
# Get key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Sentry DSN for error monitoring (optional)
# Get DSN at: https://sentry.io/
SENTRY_DSN=

# Redis URL for rate limiting (optional, uses in-memory if not set)
# Format: redis://host:port/db
REDIS_URL=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask environment (development/production)
FLASK_ENV=production

# CARA version identifier
CARA_VERSION=2.2.0

# =============================================================================
# INTERNAL API KEYS (Optional, for advanced access control)
# =============================================================================

# Primary CARA API key for internal system access
CARA_API_KEY=

# Read-only CARA API key
CARA_READONLY_API_KEY=

# Admin CARA API key
CARA_ADMIN_API_KEY=
